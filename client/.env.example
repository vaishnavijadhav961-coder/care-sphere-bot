# COSMIC QUERY - Firebase Environment Variables Example
# Copy this file to .env and fill in your details

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=care-sphere-bot.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=care-sphere-bot
VITE_FIREBASE_STORAGE_BUCKET=care-sphere-bot.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Gemini API Key — get from https://aistudio.google.com/
VITE_GEMINI_API_KEY=
